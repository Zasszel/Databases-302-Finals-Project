@page "/counter"
@rendermode InteractiveServer
@using Oracle.ManagedDataAccess.Client
@using Dapper
@using BlazorApp.Models
@using Radzen
@using Radzen.Blazor
@inject Microsoft.Extensions.Configuration.IConfiguration Configuration

<PageTitle>Kezdőlap - Rezi Statisztikák 2025</PageTitle>

<h1>Pontszámok Eloszlása (2025)</h1>

@if (isLoading)
{
    <div class="d-flex align-items-center mb-3">
        <div class="spinner-border text-primary me-2" role="status"></div>
        <span>Adatok betöltése az Oracle adatbázisból...</span>
    </div>
}
else if (error != null)
{
    <div class="alert alert-danger">
        <strong>Hiba történt:</strong> @error
    </div>
}
else
{
    <div class="row mb-5 mt-4">
        <div class="col-md-8 offset-md-2">
            <h3 class="text-center">2025-ös pontszámok kategóriánként</h3>

            @if (pieChartData != null && pieChartData.Any())
            {
                <RadzenChart>
                    <RadzenPieSeries Data="@pieChartData" Title="Vizsgázók száma" CategoryProperty="CategoryName" ValueProperty="StudentCount">
                        <RadzenSeriesDataLabels Visible="true" />
                    </RadzenPieSeries>
                    <RadzenLegend Position="LegendPosition.Right" />
                </RadzenChart>
            }
        </div>
    </div>
}

@code {
    private bool isLoading = true;
    private string? error;

    // Ide mentjük le az összes 2025-ös adatot az ExamResult modelled alapján
    private IEnumerable<ExamResult>? results2025;

    // Ez a lista fogja táplálni a tortadiagramot
    private List<ChartData> pieChartData = new();

    // Egy kis belső osztály a diagram adatainak
    public class ChartData
    {
        public string CategoryName { get; set; } = string.Empty;
        public int StudentCount { get; set; }
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        try
        {
            isLoading = true;
            error = null;

            var connStr = Configuration.GetConnectionString("Oracle");
            using var conn = new OracleConnection(connStr);

            // 1. Lekérdezzük az összes adatot a rezi_2025 táblából az ExamResult modelledbe
            string sql = "SELECT * FROM rezi_2025";
            results2025 = await conn.QueryAsync<ExamResult>(sql);

            // 2. LINQ segítségével szétválogatjuk a pontszámokat a kért kategóriákba
            if (results2025 != null && results2025.Any())
            {
                pieChartData = new List<ChartData>
                {
                    new ChartData
                    {
                        CategoryName = "< 500 pont",
                        StudentCount = results2025.Count(x => x.Scor_Simplu < 500)
                    },
                    new ChartData
                    {
                        CategoryName = "500 - 700 pont",
                        StudentCount = results2025.Count(x => x.Scor_Simplu >= 500 && x.Scor_Simplu < 700)
                    },
                    new ChartData
                    {
                        CategoryName = "700 - 900 pont",
                        StudentCount = results2025.Count(x => x.Scor_Simplu >= 700 && x.Scor_Simplu < 900)
                    },
                    new ChartData
                    {
                        CategoryName = "900 - 1000 pont",
                        StudentCount = results2025.Count(x => x.Scor_Simplu >= 900 && x.Scor_Simplu <= 1000)
                    }
                };
            }
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }
}